DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pokesignal?schema=public
APP_URL=http://localhost:3000
TCGDEX_API_URL=https://api.tcgdex.net/v2
SYNC_CARD_LIMIT=all
SYNC_BATCH_SIZE=500
SYNC_PAGE_SIZE=100
SYNC_MAX_BATCHES_PER_INVOCATION=3
SYNC_MAX_CHAIN_DEPTH=8
SYNC_RETRY_COUNT=3
SYNC_RETRY_DELAY_MS=500
AUTO_SYNC_ENABLED=true
AUTO_SYNC_CHECK_INTERVAL_MINUTES=60
MIN_HISTORY_DAYS=30
MODEL_HORIZON_DAYS=7
MODEL_ARTIFACT_PATH=python/artifacts/current-model.json
ENABLE_MODEL_SCORING=true
CRON_SECRET=replace-me-for-deployed-cron
